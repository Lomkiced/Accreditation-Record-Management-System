generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id             String            @id @default(uuid())
  authId         String            @unique @map("auth_id")
  name           String
  email          String            @unique
  role           Role              @default(FACULTY)
  department     String
  designation    String
  phone          String?
  isActive       Boolean           @default(true) @map("is_active")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  assignments    Assignment[]
  auditLogs      AuditLog[]
  logbookEntries LogbookEntry[]
  notifications  Notification[]
  documents      Document[]         // formerly: submissions
  mappings       DocumentMapping[]  // mappings this user created

  @@map("users")
}

// ─── ACCREDITATION HIERARCHY ──────────────────────────────────────────────────

model Area {
  id          String       @id @default(uuid())
  name        String
  description String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  assignments Assignment[]
  criteria    Criterion[]

  @@map("areas")
}

model Criterion {
  id          String       @id @default(uuid())
  areaId      String       @map("area_id")
  name        String
  description String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  area        Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  indicators  Indicator[]

  @@index([areaId])
  @@map("criteria")
}

model Indicator {
  id           String            @id @default(uuid())
  criterionId  String            @map("criterion_id")
  name         String
  requiredDocs String?           @map("required_docs")
  ratingScale  Int               @default(5) @map("rating_scale")
  order        Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  criterion    Criterion         @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  // Mappings are the M:N link. Deleting an indicator cascades to its mappings
  // but does NOT delete the central Document.
  mappings     DocumentMapping[]

  @@index([criterionId])
  @@map("indicators")
}

// ─── CENTRALIZED DOCUMENT REPOSITORY ─────────────────────────────────────────

/// Central file record — uploaded once, mapped to many indicators.
model Document {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  title       String
  description String?
  fileUrl     String?           @map("file_url")
  fileName    String?           @map("file_name")
  fileSize    Int?              @map("file_size")
  documentDate DateTime?        @map("document_date")
  version     Int               @default(1)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Deleting this document cascades to all its mappings.
  mappings    DocumentMapping[]
  versions    DocumentVersion[]
  tags        DocumentTag[]

  @@index([userId])
  @@map("documents")
}

/// Pivot/join table establishing M:N between Document and Indicator.
/// Status is tracked at the mapping level — a document can be "Approved"
/// for one indicator and "Under Review" for another simultaneously.
model DocumentMapping {
  id          String        @id @default(uuid())
  documentId  String        @map("document_id")
  indicatorId String        @map("indicator_id")
  userId      String        @map("user_id") // faculty member who created this mapping
  status      MappingStatus @default(DRAFT)
  remarks     String?       // admin review remarks per mapping
  rating      Int?          // self-survey rating per mapping
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Cascade: deleting a Document removes all its mappings.
  // Deleting a Mapping does NOT touch the Document (central file).
  document    Document      @relation(fields: [documentId],  references: [id], onDelete: Cascade)
  indicator   Indicator     @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId],      references: [id], onDelete: Cascade)

  @@unique([documentId, indicatorId])
  @@index([indicatorId])
  @@index([userId])
  @@index([status])
  @@map("document_mappings")
}

/// Tracks version history for a Document (file revisions).
model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  fileSize   Int?     @map("file_size")
  version    Int
  remarks    String?
  createdAt  DateTime @default(now()) @map("created_at")

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

// ─── TAGGING ──────────────────────────────────────────────────────────────────

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  type      TagType       @default(CUSTOM)
  color     String        @default("#3B82F6")
  createdAt DateTime      @default(now()) @map("created_at")

  documents DocumentTag[]

  @@map("tags")
}

/// Many-to-many between Document and Tag (custom labels / metadata tags).
model DocumentTag {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  tagId      String   @map("tag_id")

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
  @@index([documentId])
  @@index([tagId])
  @@map("document_tags")
}

// ─── ASSIGNMENTS ──────────────────────────────────────────────────────────────

model Assignment {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  areaId      String     @map("area_id")
  criterionId String?    @map("criterion_id")
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")

  area        Area       @relation(fields: [areaId], references: [id], onDelete: Cascade)
  criterion   Criterion? @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, areaId, criterionId])
  @@index([userId])
  @@index([areaId])
  @@map("assignments")
}

// ─── LOGBOOK ──────────────────────────────────────────────────────────────────

model LogbookEntry {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  type           LogbookType
  title          String
  date           DateTime
  fromTo         String        @map("from_to")
  purpose        String
  refNo          String?       @map("ref_no")
  fileUrl        String?       @map("file_url")
  fileName       String?       @map("file_name")
  status         LogbookStatus @default(PENDING)
  adminRemarks   String?       @map("admin_remarks")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("logbook_entries")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  module    String
  targetId  String?  @map("target_id")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetId])
  @@map("audit_logs")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  FACULTY
}

/// Status is tracked per DocumentMapping, not per Document.
/// A single document can be Approved for one indicator, Under Review for another.
enum MappingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  RETURNED
}

enum TagType {
  SYSTEM
  CUSTOM
}

enum LogbookType {
  INCOMING
  OUTGOING
}

enum LogbookStatus {
  PENDING
  ACKNOWLEDGED
  REJECTED
}
